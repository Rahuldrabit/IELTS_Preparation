# Production Environment Variables

# Database
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=ielts
POSTGRES_PASSWORD=secure_postgres_password_here
POSTGRES_DB=ieltsdb
DATABASE_URL=postgresql+asyncpg://ielts:secure_postgres_password_here@postgres:5432/ieltsdb
DATABASE_URL_SYNC=postgresql+psycopg2://ielts:secure_postgres_password_here@postgres:5432/ieltsdb

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# Qdrant (Vector DB)
QDRANT_URL=http://qdrant:6333

# External APIs
OPENROUTER_API_KEY=your_production_openrouter_key
OPENROUTER_MODEL=google/gemma-3-27b-it
GEMINI_API_KEY=your_production_gemini_key

# CORS Settings
CORS_ORIGINS=["https://your-production-frontend-domain.com"]

# Import storage
IMPORT_STORAGE_PATH=/app/imports
