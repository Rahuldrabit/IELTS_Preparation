# Database
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=ielts
POSTGRES_PASSWORD=ielts_secret
POSTGRES_DB=ieltsdb
DATABASE_URL=postgresql+asyncpg://ielts:ielts_secret@postgres:5432/ieltsdb
DATABASE_URL_SYNC=postgresql+psycopg2://ielts:ielts_secret@postgres:5432/ieltsdb

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# Qdrant (Vector DB)
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_URL=http://qdrant:6333

# LLM (LM Studio / OpenAI compatible) — local fallback
LLM_BASE_URL=http://host.docker.internal:1234/v1
LLM_MODEL=google/gemma-4-e4b
LLM_API_KEY=lm-studio
LLM_MAX_TOKENS=2048

# OpenRouter (cloud — primary provider if key is set)
# Get your key at https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemma-3-27b-it
OPENROUTER_MAX_TOKENS=4096

# Google AI SDK (optional — used for audio transcription and image analysis)
GEMINI_API_KEY=
GEMMA_MODEL=gemma-4-27b-it

# Gateway
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=8000

# Service Ports
PROFILE_SERVICE_PORT=8001
READING_SERVICE_PORT=8002
LISTENING_SERVICE_PORT=8003
WRITING_SERVICE_PORT=8004
VOCABULARY_SERVICE_PORT=8005
GRAMMAR_SERVICE_PORT=8006
IMPORT_SERVICE_PORT=8007
ANALYTICS_SERVICE_PORT=8008
AI_AGENT_SERVICE_PORT=8009